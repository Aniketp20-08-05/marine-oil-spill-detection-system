# Marine Oil Spill Detection System Configuration

# === Database ===
DATABASE_URL=sqlite:///./marine.db

# === API Keys ===
AISSTREAM_API_KEY=your_aisstream_key_here
PLANET_API_KEY=your_planet_api_key_here

# === Twilio SMS Configuration ===
# Get these from: https://console.twilio.com
# 1. Account SID from Account > API keys & tokens
# 2. Auth Token from Account > API keys & tokens  
# 3. Phone Number from Phone Numbers > Manage > Active Numbers

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Enable SMS sending (set to True to enable, False to disable)
ENABLE_SMS=False

# === Debug Mode ===
DEBUG=True
